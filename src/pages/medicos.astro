---
/**
 * LP /medicos
 *
 * Landing page dedicada pra médicos PJ.
 *
 * Decisão: reusa 8 dos 9 componentes da home (Verticais, ComoFunciona, Stats,
 * Depoimentos, Precos, Calculadora, CtaFinal, Midia). Substitui 3 (Hero,
 * Intro, FAQ) por versões médico-específicas pra:
 *  - Atacar palavras-chave médicas (Receita Saúde, Fator R, Anexo III)
 *  - Evitar duplicação completa com a home (canonical separado)
 *  - Servir como destino dedicado pra campanhas Ads/Meta
 *
 * JSON-LD:
 *  - Organization (Selvia)
 *  - Service específico pra contabilidade médica
 *  - FAQPage com as 6 perguntas específicas de médicos
 */

import BaseLayout from '../layouts/BaseLayout.astro';
import Announcement from '../components/layout/Announcement.astro';
import Header from '../components/layout/Header.astro';
import Footer from '../components/layout/Footer.astro';

// Componentes específicos /medicos (NOVOS)
import HeroMedicos from '../components/medicos/HeroMedicos.astro';
import IntroMedicos from '../components/medicos/IntroMedicos.astro';
import FaqMedicos from '../components/medicos/FaqMedicos.astro';

// Componentes da home reaproveitados
import Verticais from '../components/sections/Verticais.astro';
import ComoFunciona from '../components/sections/ComoFunciona.astro';
import Stats from '../components/sections/Stats.astro';
import Depoimentos from '../components/sections/Depoimentos.astro';
import Precos from '../components/sections/Precos.astro';
import Calculadora from '../components/sections/Calculadora.astro';
import CtaFinal from '../components/sections/CtaFinal.astro';
import Midia from '../components/sections/Midia.astro';

import { medicosMeta, medicosFaqs } from '../data/medicos.ts';

// === JSON-LD ===
const organizationSchema = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: 'Selvia',
  url: Astro.site?.href,
  logo: new URL('/logo.png', Astro.site).href,
  description: 'Contabilidade no WhatsApp para profissionais PJ no Brasil.',
  sameAs: [
    'https://www.linkedin.com/company/selvia-m',
    'https://www.instagram.com/selvia.contabilidade/',
  ],
};

// Service schema específico pra contabilidade médica
const serviceSchema = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  name: 'Contabilidade para Médico PJ',
  description: 'Contabilidade especializada em médicos: abertura de CNPJ, Receita Saúde, gestão de plantões, impostos automatizados e suporte no WhatsApp.',
  url: new URL('/medicos', Astro.site).href,
  provider: {
    '@type': 'Organization',
    name: 'Selvia',
    url: Astro.site?.href,
    identifier: 'CRC GO-018845/O-3',
  },
  areaServed: {
    '@type': 'Country',
    name: 'Brasil',
  },
  audience: {
    '@type': 'Audience',
    audienceType: 'Médicos PJ',
  },
  serviceType: 'Contabilidade especializada em médicos',
  offers: {
    '@type': 'Offer',
    price: '347',
    priceCurrency: 'BRL',
    availability: 'https://schema.org/InStock',
    description: 'Plano mensal pra médico PJ com abertura de CNPJ gratuita',
  },
};

// FAQPage com as perguntas específicas de médicos
const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: medicosFaqs.map((f) => ({
    '@type': 'Question',
    name: f.question,
    acceptedAnswer: {
      '@type': 'Answer',
      text: f.answer,
    },
  })),
};

const jsonLd = [organizationSchema, serviceSchema, faqSchema];
---

<BaseLayout
  title={medicosMeta.title}
  description={medicosMeta.description}
  jsonLd={jsonLd}
>
  <Announcement />
  <Header />

  <main>
    <HeroMedicos />
    <IntroMedicos />
    <Verticais />
    <ComoFunciona />
    <Stats />
    <Depoimentos />
    <Precos />
    <Calculadora />
    <FaqMedicos />
    <CtaFinal />
    <Midia />
  </main>

  <Footer />
</BaseLayout>
