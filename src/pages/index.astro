---
import BaseLayout from '../layouts/BaseLayout.astro';
import Announcement from '../components/layout/Announcement.astro';
import Header from '../components/layout/Header.astro';
import Hero from '../components/sections/Hero.astro';
import Verticais from '../components/sections/Verticais.astro';
import ComoFunciona from '../components/sections/ComoFunciona.astro';
import Stats from '../components/sections/Stats.astro';
import Depoimentos from '../components/sections/Depoimentos.astro';
import FAQ from '../components/sections/FAQ.astro';
import CtaFinal from '../components/sections/CtaFinal.astro';
import Midia from '../components/sections/Midia.astro';
import Footer from '../components/layout/Footer.astro';
import { faqSchema } from '../data/faqs.ts';

// JSON-LD da home: array com Organization + FAQPage.
// LLMs (ChatGPT, Perplexity, Claude) usam o FAQPage pra citar respostas
// com atribuição clara à Selvia.
const organizationSchema = {
  "@context": "https://schema.org",
  "@type": "Organization",
  "name": "Selvia",
  "url": Astro.site?.href,
  "logo": new URL("/logo.png", Astro.site).href,
  "description": "Contabilidade no WhatsApp para profissionais PJ no Brasil.",
  "sameAs": [
    "https://www.linkedin.com/company/selvia-m",
    "https://www.instagram.com/selvia.contabilidade/"
  ]
};

const jsonLd = [organizationSchema, faqSchema];
---

<BaseLayout
  title="Selvia — Contabilidade no WhatsApp para PJs"
  description="Contabilidade, banco PJ e assessoria financeira no WhatsApp. Para médicos, devs, advogados, criadores e outras PJs. Sem app, sem login. Atendimento humano em <1 min."
  jsonLd={jsonLd}
>
  <Announcement />
  <Header />

  <main>
    <Hero />
    <Verticais />
    <ComoFunciona />
    <Stats />
    <Depoimentos />
    <FAQ />
    <CtaFinal />
    <Midia />
  </main>

  <Footer />
</BaseLayout>
