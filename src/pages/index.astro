---
import BaseLayout from '../layouts/BaseLayout.astro';

const organizationSchema = {
  "@context": "https://schema.org",
  "@type": "Organization",
  "name": "Selvia",
  "url": Astro.site?.href,
  "logo": new URL("/logo.png", Astro.site).href,
  "description": "Contabilidade no WhatsApp para profissionais PJ no Brasil.",
  "sameAs": [
    "https://www.linkedin.com/company/selvia"
  ]
};
---

<BaseLayout
  title="Selvia — Contabilidade no WhatsApp para PJs"
  description="Contabilidade, banco PJ e assessoria financeira no WhatsApp. Para médicos, devs, advogados, criadores e outras PJs. Sem app, sem login. Atendimento humano em <1 min."
  jsonLd={organizationSchema}
>
  <main>
    <h1>Selvia — em migração</h1>
    <p>SEO setup completo. Próximo passo: trazer o conteúdo do <code>_legacy/index.html</code>.</p>

    <h2>Páginas planejadas (vão existir já no primeiro deploy):</h2>
    <ul>
      <li>/medicos</li>
      <li>/devs</li>
      <li>/advogados</li>
      <li>/criadores</li>
      <li>/saude</li>
      <li>/outras-pj</li>
      <li>/contabilidades</li>
      <li>/sobre</li>
      <li>/imprensa</li>
      <li>/blog</li>
      <li>/calculadoras/impostos</li>
    </ul>
  </main>
</BaseLayout>
