---
/**
 * Curve - componente decorativo de fundo
 * 1:1 com _legacy/index.html (CSS 1898-1983)
 *
 * Renderiza a "curva orgânica 3D" que é elemento de marca da Selvia:
 *   - Camada 1: sombra preta borrada (gera profundidade — efeito 3D)
 *   - Camada 2: curva colorida (cor por variant)
 *   - Camada 3: highlight fino sobre a curva (cria brilho)
 *
 * Posicionamento via CSS:
 *   - width: 120vw (vaza pras laterais — sensação de continuidade)
 *   - opacity por variant (sempre baixa: 0.10–0.30 — é fundo, não conteúdo)
 *   - clip-path polygon diagonal (anima da esquerda pra direita ao entrar no viewport)
 *   - filter: blur(4px) (etérea, parece "fundo desfocado de filme")
 *
 * ------------------------------------------------------------------
 * TODO: SUBSTITUIR SVG INLINE PELOS PNGs OFICIAIS DA SELVIA
 * ------------------------------------------------------------------
 */

interface Props {
  variant:
    | 'hero'
    | 'verticais'
    | 'como'
    | 'stats'
    | 'depoimentos'
    | 'faq'
    | 'cta-final'
    | 'midia'
    | 'precos';
}

const { variant } = Astro.props;

interface CurveConfig {
  curveColor: string;
  highlightColor: string;
  shadowOpacity: number;
}

// Cores das 3 camadas (sombra preta é fixa, curva e highlight variam por variant)
const configs: Record<Props['variant'], CurveConfig> = {
  hero:        { curveColor: '#69E470', highlightColor: '#C4F5C8', shadowOpacity: 0.30 },
  verticais:   { curveColor: '#0D423F', highlightColor: '#2A6862', shadowOpacity: 0.30 },
  como:        { curveColor: '#0D423F', highlightColor: '#2A6862', shadowOpacity: 0.30 },
  stats:       { curveColor: '#69E470', highlightColor: '#C4F5C8', shadowOpacity: 0.30 },
  depoimentos: { curveColor: '#0D423F', highlightColor: '#2A6862', shadowOpacity: 0.30 },
  faq:         { curveColor: '#0D423F', highlightColor: '#2A6862', shadowOpacity: 0.20 },
  'cta-final': { curveColor: '#FFFFFF', highlightColor: '#FFFFFF', shadowOpacity: 0.55 },
  midia:       { curveColor: '#0D423F', highlightColor: '#2A6862', shadowOpacity: 0.30 },
  precos:      { curveColor: '#69E470', highlightColor: '#C4F5C8', shadowOpacity: 0.30 },
};

const c = configs[variant];
const filterId = `curve-shadow-${variant}`;
---

<div class={`curve curve-${variant}`}>
  <svg viewBox="0 -50 1400 320" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="none">
    <defs>
      <filter id={filterId} x="-15%" y="-30%" width="130%" height="180%">
        <feGaussianBlur stdDeviation="12" />
      </filter>
    </defs>

    {/* Camada 1: sombra preta borrada (cria profundidade — efeito 3D) */}
    <path
      d="M -30 130 C 200 40, 380 200, 560 110 C 700 40, 820 80, 880 150 C 920 200, 870 230, 820 200 C 770 170, 810 100, 920 120 C 1080 150, 1220 90, 1430 50"
      stroke="#000000"
      stroke-width="34"
      stroke-linecap="round"
      fill="none"
      opacity={c.shadowOpacity}
      filter={`url(#${filterId})`}
      transform="translate(8, 20)"
    />

    {/* Camada 2: curva principal (cor por variant) */}
    <path
      d="M -30 130 C 200 40, 380 200, 560 110 C 700 40, 820 80, 880 150 C 920 200, 870 230, 820 200 C 770 170, 810 100, 920 120 C 1080 150, 1220 90, 1430 50"
      stroke={c.curveColor}
      stroke-width="26"
      stroke-linecap="round"
      fill="none"
    />

    {/* Camada 3: highlight (linha fina por cima, simula brilho/reflexo) */}
    <path
      d="M -30 130 C 200 40, 380 200, 560 110 C 700 40, 820 80, 880 150 C 920 200, 870 230, 820 200 C 770 170, 810 100, 920 120 C 1080 150, 1220 90, 1430 50"
      stroke={c.highlightColor}
      stroke-width="7"
      stroke-linecap="round"
      fill="none"
      opacity="0.7"
      transform="translate(-1, -3)"
    />
  </svg>
</div>

<style>
  /* === Layout base — 1:1 com legacy 1902-1920 === */
  .curve {
    position: absolute;
    pointer-events: none;
    z-index: 0;
    clip-path: polygon(0% 0%, 0% 0%, -3% 100%, -3% 100%);
    transition: clip-path 3.2s cubic-bezier(0.65, 0, 0.35, 1);
    filter: blur(4px);
  }
  .curve svg {
    width: 100%;
    height: 100%;
    display: block;
  }
  /* Quando a section pai entra no viewport, a curva é "desenhada" da esquerda pra direita */
  :global(.scroll-animate.is-visible) .curve,
  :global(.hero.is-visible) .curve,
  :global(.is-playing) .curve {
    clip-path: polygon(0% 0%, 110% 0%, 105% 100%, -3% 100%);
    transition-delay: 0.3s;
  }

  /* === Posicionamento por variant — 1:1 com legacy 1923-1964 === */
  .curve-hero {
    width: 120vw; height: 320px;
    bottom: 8%; left: 50%;
    transform: translateX(-50%);
    opacity: 0.30;
  }
  .curve-verticais {
    width: 120vw; height: 320px;
    top: 58%; left: 50%;
    transform: translateX(-50%);
    opacity: 0.20;
  }
  .curve-como {
    width: 120vw; height: 320px;
    top: 22%; left: 50%;
    transform: translateX(-50%);
    opacity: 0.10;
  }
  .curve-stats {
    width: 120vw; height: 320px;
    top: 28%; left: 50%;
    transform: translateX(-50%);
    opacity: 0.22;
  }
  .curve-depoimentos {
    width: 120vw; height: 320px;
    top: 52%; left: 50%;
    transform: translateX(-50%);
    opacity: 0.20;
  }
  .curve-faq {
    /* FAQ não tinha curva no legacy. Mantenho discreta caso a gente ative depois. */
    width: 120vw; height: 320px;
    top: 60%; left: 50%;
    transform: translateX(-50%);
    opacity: 0.08;
  }
  .curve-precos {
    width: 120vw; height: 320px;
    top: 18%; left: 50%;
    transform: translateX(-50%);
    opacity: 0.22;
  }
  .curve-cta-final {
    width: 120%; height: 220px;
    top: 50%; left: 50%;
    transform: translate(-50%, -50%);
    opacity: 0.18;
  }
  .curve-midia {
    width: 120vw; height: 280px;
    top: 50%; left: 50%;
    transform: translateX(-50%);
    opacity: 0.22;
  }

  /* === Mobile: curva menor, blur menor (performance) === */
  @media (max-width: 900px) {
    .curve {
      filter: blur(2px);
      height: 180px !important;
      width: 110vw !important;
      opacity: 0.12 !important;
    }
    .curve-hero { bottom: 4%; opacity: 0.25 !important; }
  }

  /* Reduced motion */
  @media (prefers-reduced-motion: reduce) {
    .curve {
      clip-path: polygon(0% 0%, 110% 0%, 105% 100%, -3% 100%);
      transition: none;
    }
  }
</style>
