---
// PrecosVertical — preços da LP vertical específica (/devs, /advogados, etc.)
//
// Diferenças em relação a Precos.astro (home):
//   - SEM tabs (não tem opção de trocar vertical — você já tá na LP daquela)
//   - 3 cards da vertical direto, com badge "Mais escolhido" no featured
//   - Title "Planos para Devs" / "Planos para Advogados" etc.
//   - CTA contextualizado no botão de cada card
//
// Reusa CSS pesado de Precos.astro (que está no global.css de Sub-etapa C).
// Não adicionamos os mesmos estilos aqui — mantemos código DRY.
//
// Visual:
//   - Background verde escuro
//   - Glows verde + azul
//   - 3 cards brancos: Simples Basic (featured), Lucro Pro, e MEI/disabled
//   - Curva decorativa via <Curve variant="precos" />

import Curve from '../ui/Curve.astro';
import { getVertical } from '../../data/verticais.ts';

interface Props {
  slug: string;       // qual vertical: 'devs', 'advogados', etc.
  verticalName: string;  // nome legível pra título: 'Devs', 'Advogados', etc.
}

const { slug, verticalName } = Astro.props;

const vertical = getVertical(slug);
if (!vertical) {
  throw new Error(
    `PrecosVertical: vertical "${slug}" não encontrada em verticais.ts. ` +
    `Verticais disponíveis: medicos, devs, advogados, criadores, saude, outras`
  );
}

// Pré-calcula classes pra cada card (evita expressão complexa inline,
// que o parser do esbuild não curte)
const planCards = vertical.plans.map((p) => {
  const classes = ['price-card'];
  if (p.featured) classes.push('featured');
  if (p.isMei) classes.push('price-card-mei');
  if (p.status === 'unavailable') classes.push('price-card-disabled');
  return {
    ...p,
    cardClass: classes.join(' '),
  };
});

const WHATSAPP_BASE = 'https://api.whatsapp.com/send?phone=5511936220451&text=';
const whatsappLink = (context: string) =>
  WHATSAPP_BASE + encodeURIComponent(`Olá! Quero saber sobre o plano ${context}`);
---

<section id="precos" class="precos-bg precos-vertical scroll-animate" data-parallax>
  <Curve variant="precos" />

  <div class="container">
    <span class="pill pill-light">Preços</span>
    <h2 class="h2 h2-light">Planos para {verticalName}.</h2>
    <p class="section-sub section-sub-light">Sem fidelidade. Abertura de CNPJ grátis. Cancele quando quiser.</p>

    <div class="price-grid precos-vertical-grid">
      {planCards.map((plan) => (
        <div class={plan.cardClass}>
          <p class="price-modalidade">{plan.modalidade}</p>
          <p class="price-plano">{plan.plano}</p>

          {plan.price && (
            <p class="price-value">{plan.price}<span class="price-value-sub">{plan.priceSuffix}</span></p>
          )}

          {plan.features && (
            <ul class="price-features">
              {plan.features.map((feat) => (
                <li>
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                       stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <path d="M5 12l5 5l10 -10" />
                  </svg>
                  {feat}
                </li>
              ))}
            </ul>
          )}

          {plan.disclaimer && plan.disclaimer.map((d, i) => (
            <p class="price-disclaimer" style={i === plan.disclaimer.length - 1 ? 'margin-top: auto;' : ''}>
              {d}
            </p>
          ))}

          {plan.status === 'available' && (
            <a href={whatsappLink(plan.whatsappContext)} target="_blank" rel="noopener" class="price-btn">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                   stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M3 21l1.65 -3.8a9 9 0 1 1 3.4 2.9l-5.05 .9" />
              </svg>
              Falar no WhatsApp
            </a>
          )}
        </div>
      ))}
    </div>

    <p class="precos-vertical-trust">
      Tem dúvida sobre qual plano é o ideal pra você?
      <a href={whatsappLink(`escolher plano de ${verticalName}`)} target="_blank" rel="noopener">
        Fale com um especialista da Selvia →
      </a>
    </p>
  </div>
</section>

<style>
  /* === PRECOS VERTICAL ===
     Reusa o background, glows e estilos de card já definidos em Precos.astro
     (Sub-etapa C.2). Aqui só ajustamos o que é específico da LP vertical:
     - Grid centralizado, max-width 1040px (visualmente "menos largo")
     - Linha de confiança embaixo (trust)
  */
  .precos-vertical-grid {
    max-width: 1040px;
    margin: 32px auto 0;
  }

  .precos-vertical-trust {
    text-align: center;
    margin: 32px auto 0;
    color: rgba(249,249,249,0.7);
    font-size: 14px;
  }
  .precos-vertical-trust a {
    color: var(--c-green-light);
    font-weight: 500;
    text-decoration: none;
    margin-left: 4px;
    transition: opacity 0.15s;
  }
  .precos-vertical-trust a:hover {
    opacity: 0.85;
  }

  /* === Importação dos estilos compartilhados com Precos.astro ===
     Como o componente Precos.astro original aplica os estilos via <style scoped>,
     eles não vazam pra outros componentes. Por isso replicamos o necessário aqui.
  */

  /* Background */
  .precos-bg {
    background: var(--c-green-dark);
    color: var(--c-offwhite);
    position: relative;
    overflow: hidden;
  }
  .precos-bg::before {
    content: '';
    position: absolute;
    top: -100px; right: -100px;
    width: 500px; height: 500px;
    background: radial-gradient(circle, rgba(105,228,112,0.18) 0%, transparent 65%);
    pointer-events: none;
  }
  .precos-bg::after {
    content: '';
    position: absolute;
    bottom: -150px; left: -100px;
    width: 450px; height: 450px;
    background: radial-gradient(circle, rgba(132,160,255,0.14) 0%, transparent 65%);
    pointer-events: none;
  }
  .precos-bg :global(.container) {
    position: relative;
    z-index: 1;
  }

  /* Grid de cards */
  .price-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 16px;
  }
  .price-grid > * { min-width: 0; }

  /* Card padrão */
  .price-card {
    background: #FFFFFF;
    border: 1px solid rgba(255,255,255,0.15);
    border-radius: 14px;
    padding: 28px 24px;
    position: relative;
    display: flex;
    flex-direction: column;
    color: var(--c-green-dark);
    box-shadow: 0 16px 32px -12px rgba(0,0,0,0.25);
  }
  .price-card.featured {
    border: 2px solid var(--c-green-light);
    box-shadow:
      0 24px 60px -8px rgba(105,228,112,0.35),
      0 12px 24px -8px rgba(0,0,0,0.3);
    transform: translateY(-4px);
  }
  .price-card.featured::before {
    content: 'Mais escolhido';
    position: absolute;
    top: -12px;
    left: 20px;
    background: var(--c-green-light);
    color: var(--c-green-dark);
    padding: 4px 12px;
    border-radius: 100px;
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.3px;
    box-shadow: 0 4px 12px rgba(105,228,112,0.4);
  }
  .price-card-mei {
    background: #FFFFFF;
    border: 2px solid var(--c-green-light);
    position: relative;
  }
  .price-card-mei::before {
    content: 'MEI · Pra começar';
    position: absolute;
    top: -12px;
    left: 20px;
    background: linear-gradient(135deg, #69E470 0%, #5FD466 100%);
    color: var(--c-green-dark);
    padding: 4px 12px;
    border-radius: 100px;
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.3px;
    box-shadow: 0 4px 12px rgba(105,228,112,0.3);
  }
  .price-card-disabled {
    background: rgba(255,255,255,0.85);
    opacity: 0.7;
    box-shadow: none;
  }

  /* Tipografia interna */
  .price-modalidade {
    font-size: 10px;
    color: #0F6E56;
    font-weight: 500;
    letter-spacing: 0.8px;
    margin: 0;
  }
  .price-card-disabled .price-modalidade { color: #888; }
  .price-plano {
    font-size: 18px;
    font-weight: 500;
    color: var(--c-green-dark);
    margin: 6px 0 14px;
  }
  .price-value {
    font-size: 36px;
    font-weight: 500;
    color: var(--c-green-dark);
    margin: 0;
    line-height: 1;
  }
  .price-value-sub {
    font-size: 14px;
    color: var(--c-text-muted);
    font-weight: 400;
  }
  .price-features {
    margin: 20px 0;
    padding: 0;
    list-style: none;
    flex-grow: 1;
  }
  .price-features li {
    font-size: 13px;
    color: var(--c-text-muted-strong);
    margin-bottom: 10px;
    display: flex;
    align-items: flex-start;
    gap: 8px;
    line-height: 1.5;
  }
  .price-features li svg {
    color: var(--c-green-whatsapp);
    flex-shrink: 0;
    margin-top: 2px;
  }
  .price-btn {
    width: 100%;
    padding: 12px;
    background: var(--c-green-dark);
    color: var(--c-green-light);
    border: none;
    border-radius: 8px;
    font-weight: 500;
    font-size: 13px;
    cursor: pointer;
    transition: all 0.15s;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    text-decoration: none;
    font-family: inherit;
  }
  .price-btn:hover {
    background: #082c2a;
    box-shadow: 0 6px 16px rgba(13,66,63,0.25);
  }
  .price-card-mei .price-btn {
    background: var(--c-green-light);
    color: var(--c-green-dark);
  }
  .price-card-mei .price-btn:hover {
    background: #4dd055;
    box-shadow: 0 6px 16px rgba(105,228,112,0.35);
  }
  .price-disclaimer {
    font-size: 13px;
    color: var(--c-text-muted);
    line-height: 1.6;
    margin: 12px 0;
  }

  /* === Mobile === */
  @media (max-width: 900px) {
    .price-grid {
      grid-template-columns: 1fr;
    }
    .price-card.featured {
      transform: none;
    }
  }
</style>
