---
// HeroVertical — Hero customizado pras LPs verticais (/devs, /advogados, etc.)
// Diferenças em relação ao Hero da home:
//   - Recebe eyebrow + h1 + sub via props (conteúdo único por vertical)
//   - Sem mock chat do WhatsApp (foco no message proposition específico)
//   - Layout mais "spotlight": coluna única centralizada, hero respira mais
//   - CTA principal WhatsApp + CTA secundário "Ver preços" linkando pra #precos
//
// Visual mantém o padrão da home:
//   - Background verde escuro
//   - Glow blobs decorativos (verde + azul)
//   - Curva decorativa via <Curve variant="hero" />
//   - Botões iguais (.btn-primary, .btn-secondary)

import Curve from '../ui/Curve.astro';

interface Props {
  eyebrow: string;   // pill pequeno em cima do H1
  h1: string;        // headline grande
  sub: string;       // subheadline abaixo do H1
  whatsappContext?: string;  // texto pra mensagem do WhatsApp (default: slug vertical)
}

const { eyebrow, h1, sub, whatsappContext = 'LP vertical' } = Astro.props;

const WHATSAPP_BASE = 'https://api.whatsapp.com/send?phone=5511936220451&text=';
const whatsappUrl =
  WHATSAPP_BASE +
  encodeURIComponent(`Olá! Vim da página ${whatsappContext} e gostaria de saber mais.`);
---

<section class="hero hero-vertical scroll-animate" data-parallax>
  <Curve variant="hero" />

  <div class="container hero-vertical-content">
    <span class="pill pill-light hero-vertical-eyebrow">{eyebrow}</span>

    <h1 class="hero-vertical-h1">{h1}</h1>

    <p class="hero-vertical-sub">{sub}</p>

    <div class="hero-vertical-ctas">
      <a href={whatsappUrl} target="_blank" rel="noopener" class="btn btn-primary hero-vertical-btn-main">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor"
             stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M3 21l1.65 -3.8a9 9 0 1 1 3.4 2.9l-5.05 .9" />
          <path d="M9 10a.5 .5 0 0 0 1 0v-1a.5 .5 0 0 0 -1 0v1a5 5 0 0 0 5 5h1a.5 .5 0 0 0 0 -1h-1a.5 .5 0 0 0 0 1" />
        </svg>
        Falar com a Selvia
      </a>

      <a href="#precos" class="btn btn-secondary hero-vertical-btn-sec">
        Ver preços
        <span aria-hidden="true">↓</span>
      </a>
    </div>

    <p class="hero-vertical-trust">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor"
           stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M9 12l2 2l4 -4" />
        <path d="M12 3a12 12 0 0 0 8.5 3a12 12 0 0 1 -8.5 15a12 12 0 0 1 -8.5 -15a12 12 0 0 0 8.5 -3" />
      </svg>
      +1.000 profissionais já contam com a Selvia
    </p>
  </div>
</section>

<style>
  /* === HERO VERTICAL — verde escuro com glows === */
  .hero-vertical {
    background: var(--c-green-dark);
    color: var(--c-offwhite);
    position: relative;
    overflow: hidden;
    padding: 80px 0 100px;
  }
  /* Glow verde claro topo-direita */
  .hero-vertical::before {
    content: '';
    position: absolute;
    top: -100px; right: -100px;
    width: 500px; height: 500px;
    background: radial-gradient(circle, rgba(105,228,112,0.20) 0%, transparent 65%);
    pointer-events: none;
    z-index: 0;
  }
  /* Glow azul base-esquerda */
  .hero-vertical::after {
    content: '';
    position: absolute;
    bottom: -150px; left: -100px;
    width: 450px; height: 450px;
    background: radial-gradient(circle, rgba(132,160,255,0.16) 0%, transparent 65%);
    pointer-events: none;
    z-index: 0;
  }

  /* Container do conteúdo (spotlight central) */
  .hero-vertical-content {
    position: relative;
    z-index: 2;
    max-width: 760px;
    margin: 0 auto;
    text-align: center;
  }

  /* Eyebrow pill */
  .hero-vertical-eyebrow {
    margin-bottom: 24px;
    display: inline-block;
  }

  /* Headline (grande) */
  .hero-vertical-h1 {
    font-size: clamp(36px, 5.5vw, 64px);
    font-weight: 500;
    line-height: 1.1;
    letter-spacing: -1.5px;
    color: var(--c-offwhite);
    margin: 0 0 20px;
  }

  /* Subheadline */
  .hero-vertical-sub {
    font-size: 18px;
    line-height: 1.55;
    color: rgba(249,249,249,0.82);
    margin: 0 auto 36px;
    max-width: 580px;
  }

  /* CTAs */
  .hero-vertical-ctas {
    display: inline-flex;
    gap: 12px;
    align-items: center;
    flex-wrap: wrap;
    justify-content: center;
    margin-bottom: 28px;
  }
  .hero-vertical-btn-main {
    font-size: 15px;
    padding: 14px 26px;
  }
  .hero-vertical-btn-sec {
    font-size: 15px;
    padding: 14px 22px;
    /* CTA secundário em fundo escuro: outline verde claro */
    background: transparent;
    color: var(--c-green-light);
    border: 1px solid rgba(105,228,112,0.45);
    border-radius: 8px;
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    gap: 8px;
    transition: all 0.15s;
    font-family: inherit;
    font-weight: 500;
  }
  .hero-vertical-btn-sec:hover {
    background: rgba(105,228,112,0.08);
    border-color: var(--c-green-light);
  }

  /* Linha de confiança/social proof */
  .hero-vertical-trust {
    font-size: 13px;
    color: rgba(249,249,249,0.65);
    margin: 0;
    display: inline-flex;
    align-items: center;
    gap: 8px;
  }
  .hero-vertical-trust svg {
    color: var(--c-green-light);
    flex-shrink: 0;
  }

  /* === Mobile === */
  @media (max-width: 700px) {
    .hero-vertical {
      padding: 56px 0 72px;
    }
    .hero-vertical-content {
      padding: 0 8px;
    }
    .hero-vertical-h1 {
      letter-spacing: -1px;
    }
    .hero-vertical-sub {
      font-size: 16px;
    }
    .hero-vertical-ctas {
      width: 100%;
    }
    .hero-vertical-btn-main,
    .hero-vertical-btn-sec {
      flex: 1 1 100%;
      justify-content: center;
    }
  }
</style>
