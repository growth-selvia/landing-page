---
// Verticais — segunda seção da home
// 1:1 com _legacy/index.html (CSS linhas 587-700, HTML 2150-2208)
//
// NOTA: SVGs inline em cada card (não via set:html do data file)
// — evita erro de parser do esbuild com expressões complexas dentro de SVG.
// Os textos/links continuam vindo de src/data/verticais.ts.

import Curve from '../ui/Curve.astro';
import { VERTICAIS } from '../../data/verticais.ts';

const v0 = VERTICAIS[0]; // medicos
const v1 = VERTICAIS[1]; // devs
const v2 = VERTICAIS[2]; // advogados
const v3 = VERTICAIS[3]; // criadores
const v4 = VERTICAIS[4]; // saude
const v5 = VERTICAIS[5]; // outras
---

<section id="verticais" class="verticais-bg scroll-animate" data-parallax>
  <Curve variant="verticais" />

  <div class="container">
    <span class="pill pill-dark">Pra quem é</span>
    <h2 class="h2">A Selvia é para você se é:</h2>
    <p class="section-sub">
      Atendimento especializado por profissão, com contadores que entendem
      do seu mundo. Clica e vê o plano da sua área.
    </p>

    <div class="verticais-grid stagger-children">
      <a href={v0.futurePage} data-vertical={v0.slug} class="vertical-card vertical-link">
        <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M6 4h-1a2 2 0 0 0 -2 2v3.5h0a5.5 5.5 0 0 0 11 0v-3.5a2 2 0 0 0 -2 -2h-1" />
          <rect x="4" y="3" width="3" height="3" rx=".5" />
          <rect x="11" y="3" width="3" height="3" rx=".5" />
          <path d="M8 15a6 6 0 1 0 12 0v-3" />
          <path d="M20 11m-2 0a2 2 0 1 0 4 0a2 2 0 1 0 -4 0" />
        </svg>
        <h3>{v0.name}</h3>
        <p>{v0.description}</p>
        <span class="vertical-arrow">Ver plano →</span>
      </a>

      <a href={v1.futurePage} data-vertical={v1.slug} class="vertical-card vertical-link">
        <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M7 8l-4 4l4 4" />
          <path d="M17 8l4 4l-4 4" />
          <path d="M14 4l-4 16" />
        </svg>
        <h3>{v1.name}</h3>
        <p>{v1.description}</p>
        <span class="vertical-arrow">Ver plano →</span>
      </a>

      <a href={v2.futurePage} data-vertical={v2.slug} class="vertical-card vertical-link">
        <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M7 20l10 0" />
          <path d="M6 6l6 -1l6 1" />
          <path d="M12 3l0 17" />
          <path d="M9 12l-3 -6l-3 6a3 3 0 0 0 6 0" />
          <path d="M21 12l-3 -6l-3 6a3 3 0 0 0 6 0" />
        </svg>
        <h3>{v2.name}</h3>
        <p>{v2.description}</p>
        <span class="vertical-arrow">Ver plano →</span>
      </a>

      <a href={v3.futurePage} data-vertical={v3.slug} class="vertical-card vertical-link">
        <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M9 2m0 3a3 3 0 0 1 3 -3h0a3 3 0 0 1 3 3v5a3 3 0 0 1 -3 3h0a3 3 0 0 1 -3 -3z" />
          <path d="M5 10a7 7 0 0 0 14 0" />
          <path d="M8 21l8 0" />
          <path d="M12 17l0 4" />
        </svg>
        <h3>{v3.name}</h3>
        <p>{v3.description}</p>
        <span class="vertical-arrow">Ver plano →</span>
      </a>

      <a href={v4.futurePage} data-vertical={v4.slug} class="vertical-card vertical-link">
        <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M19.5 12.572l-7.5 7.428l-7.5 -7.428a5 5 0 1 1 7.5 -6.566a5 5 0 1 1 7.5 6.572" />
        </svg>
        <h3>{v4.name}</h3>
        <p>{v4.description}</p>
        <span class="vertical-arrow">Ver plano →</span>
      </a>

      <a href={v5.futurePage} data-vertical={v5.slug} class="vertical-card vertical-link">
        <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M3 7m0 2a2 2 0 0 1 2 -2h14a2 2 0 0 1 2 2v9a2 2 0 0 1 -2 2h-14a2 2 0 0 1 -2 -2z" />
          <path d="M8 7v-2a2 2 0 0 1 2 -2h4a2 2 0 0 1 2 2v2" />
          <path d="M12 12l0 .01" />
          <path d="M3 13a20 20 0 0 0 18 0" />
        </svg>
        <h3>{v5.name}</h3>
        <p>{v5.description}</p>
        <span class="vertical-arrow">Ver plano →</span>
      </a>
    </div>
  </div>
</section>

<style>
  .verticais-bg {
    background:
      radial-gradient(circle, rgba(13,66,63,0.06) 1px, transparent 1.5px) 0 0 / 28px 28px,
      linear-gradient(180deg, #FFFFFF 0%, #F9F9F9 100%);
    position: relative;
    overflow: hidden;
  }
  .verticais-bg::before {
    content: '';
    position: absolute;
    top: -100px; left: -80px;
    width: 420px; height: 420px;
    background: radial-gradient(circle, rgba(105,228,112,0.25) 0%, transparent 65%);
    filter: blur(60px);
    pointer-events: none;
  }
  .verticais-bg::after {
    content: '';
    position: absolute;
    bottom: -100px; right: -80px;
    width: 360px; height: 360px;
    background: radial-gradient(circle, rgba(132,160,255,0.20) 0%, transparent 65%);
    filter: blur(60px);
    pointer-events: none;
  }
  .verticais-bg :global(.container) {
    position: relative;
    z-index: 1;
  }

  .verticais-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
    margin-top: 16px;
  }
  .verticais-grid > * { min-width: 0; }

  .vertical-card {
    background: #FFFFFF;
    border-radius: 14px;
    padding: 28px 24px 22px;
    border: 1px solid rgba(13,66,63,0.08);
    transition: transform 0.2s ease, box-shadow 0.2s ease, border-color 0.2s ease;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    text-decoration: none;
    color: inherit;
  }
  .vertical-card:hover {
    transform: translateY(-3px);
    box-shadow: 0 12px 32px rgba(13,66,63,0.10);
    border-color: rgba(105,228,112,0.4);
  }
  .vertical-card svg {
    color: var(--c-green-medium);
    margin-bottom: 14px;
    flex-shrink: 0;
  }
  .vertical-card h3 {
    font-size: 18px;
    font-weight: 500;
    color: var(--c-green-dark);
    margin: 0 0 6px;
    line-height: 1.2;
  }
  .vertical-card p {
    font-size: 13px;
    color: var(--c-text-muted);
    line-height: 1.5;
    margin: 0 0 18px;
    flex-grow: 1;
  }
  .vertical-arrow {
    font-size: 13px;
    font-weight: 500;
    color: var(--c-green-dark);
    transition: gap 0.2s;
  }
  .vertical-card:hover .vertical-arrow {
    color: var(--c-green-medium);
  }

  @media (max-width: 900px) {
    .verticais-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  @media (max-width: 560px) {
    .verticais-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
