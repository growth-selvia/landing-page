---
// Como Funciona — terceira seção da home
// 1:1 com _legacy/index.html (CSS linhas 666-898, HTML 2210-2287, JS 3316-3400)
//
// Estrutura:
// - Background gradient verde claro vibrante + dots pattern
// - Pill + h2 + subheadline
// - 3 passos horizontais: ícone com glow + shine + número GIGANTE (140px) + texto
// - Linhas pontilhadas conectoras posicionadas via JS baseado no rect dos números
// - Curva decorativa via <Curve variant="como" />
//
// Animação:
// - Quando section entra no viewport, ganha classe .is-playing
// - Em cadeia: cada step anima visual → number → body com stagger 100ms entre cada
// - Glow externo do ícone pulsa infinitamente (4s loop, delays escalonados)
// - Shine traveling atravessa o ícone diagonalmente (4.5s loop)
// - Linhas conectoras animam scaleX(0) → scaleX(1) após os números aparecerem

import Curve from '../ui/Curve.astro';
---

<section class="como-funciona-bg" data-parallax>
  <Curve variant="como" />

  <div class="container">
    <span class="pill pill-dark">Como funciona</span>
    <h2 class="h2">Três passos para economizar impostos</h2>
    <p class="section-sub">Sem app pra baixar, sem cadastro. Tudo acontece no seu WhatsApp.</p>

    <div class="steps-h">
      <div class="step-h">
        <div class="step-h-visual">
          <div class="step-h-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"
                 stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z" />
            </svg>
          </div>
        </div>
        <div class="step-h-number">1</div>
        <div class="step-h-body">
          <h3 class="step-h-title">Você manda mensagem</h3>
          <p class="step-h-desc">
            Texto, áudio, foto, PDF, a Selvia entende qualquer formato.
            A gente responde em minutos direto no seu WhatsApp.
          </p>
        </div>
      </div>

      <div class="step-h">
        <div class="step-h-visual">
          <div class="step-h-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"
                 stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M12 3 L13.5 8.5 L19 10 L13.5 11.5 L12 17 L10.5 11.5 L5 10 L10.5 8.5 Z" />
              <path d="M19 3 L19.7 5 L21.5 5.7 L19.7 6.4 L19 8.4 L18.3 6.4 L16.5 5.7 L18.3 5 Z" />
              <path d="M5 14 L5.7 16 L7.5 16.7 L5.7 17.4 L5 19.4 L4.3 17.4 L2.5 16.7 L4.3 16 Z" />
            </svg>
          </div>
        </div>
        <div class="step-h-number">2</div>
        <div class="step-h-body">
          <h3 class="step-h-title">A Selvia cuida de tudo</h3>
          <p class="step-h-desc">
            Abertura de CNPJ, emissão de NF-e, pagamento de DAS,
            contabilidade mensal, IRPF. Você só vê o resultado.
          </p>
        </div>
      </div>

      <div class="step-h">
        <div class="step-h-visual">
          <div class="step-h-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"
                 stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <polyline points="23 6 13.5 15.5 8.5 10.5 1 18" />
              <polyline points="17 6 23 6 23 12" />
            </svg>
          </div>
        </div>
        <div class="step-h-number">3</div>
        <div class="step-h-body">
          <h3 class="step-h-title">Você decide com clareza</h3>
          <p class="step-h-desc">
            Relatório mensal: quanto entrou, quanto saiu, quanto sobrou.
            Quer investir? Temos assessor pra te ajudar.
          </p>
        </div>
      </div>

      <div class="steps-h-segment" data-segment="1" aria-hidden="true"></div>
      <div class="steps-h-segment" data-segment="2" aria-hidden="true"></div>
    </div>
  </div>
</section>

<style>
  /* === COMO FUNCIONA — verde claro vibrante com dots === */
  .como-funciona-bg {
    background:
      radial-gradient(circle, rgba(13,66,63,0.08) 1px, transparent 1.5px) 0 0 / 28px 28px,
      radial-gradient(ellipse at top left, #7DEC83 0%, #69E470 50%, #5FD466 100%);
    position: relative;
    overflow: hidden;
  }
  .como-funciona-bg::before {
    content: '';
    position: absolute;
    bottom: -100px; right: -100px;
    width: 400px; height: 400px;
    background: radial-gradient(circle, rgba(13,66,63,0.10) 0%, transparent 70%);
    filter: blur(40px);
    pointer-events: none;
  }
  .como-funciona-bg::after {
    content: '';
    position: absolute;
    top: -50px; right: 10%;
    width: 320px; height: 320px;
    background: radial-gradient(circle, rgba(255,255,255,0.25) 0%, transparent 65%);
    filter: blur(50px);
    pointer-events: none;
  }
  .como-funciona-bg :global(.container) {
    position: relative;
    z-index: 1;
  }

  /* === Layout horizontal === */
  .steps-h {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 32px;
    position: relative;
    margin-top: 56px;
    padding: 0 8px;
  }
  .step-h {
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
  }

  /* === Ícone com glow pulsante e shine traveling === */
  .step-h-visual {
    width: 100px;
    height: 100px;
    margin-bottom: 8px;
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  /* Glow externo pulsante — efeito de "respiração" premium */
  .step-h-visual::before {
    content: '';
    position: absolute;
    inset: -10px;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(255,255,255,0.45) 0%, transparent 65%);
    filter: blur(14px);
    pointer-events: none;
    z-index: 0;
    animation: icon-glow-pulse 4s ease-in-out infinite;
  }
  .step-h-icon {
    width: 96px;
    height: 96px;
    border-radius: 50%;
    background: radial-gradient(circle at 30% 30%, rgba(255,255,255,0.55) 0%, rgba(255,255,255,0.15) 40%, transparent 70%);
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
    z-index: 1;
    overflow: hidden;
    isolation: isolate;
  }
  /* Shine traveling: faixa de luz atravessando diagonalmente */
  .step-h-icon::after {
    content: '';
    position: absolute;
    top: -20%;
    left: -50%;
    width: 60%;
    height: 140%;
    background: linear-gradient(
      105deg,
      transparent 0%,
      rgba(255,255,255,0.35) 40%,
      rgba(255,255,255,0.85) 50%,
      rgba(255,255,255,0.35) 60%,
      transparent 100%
    );
    transform: translateX(-100%) skewX(-15deg);
    animation: icon-shine 4.5s ease-in-out infinite;
    pointer-events: none;
    z-index: 1;
  }
  .step-h-icon svg {
    width: 44px;
    height: 44px;
    color: var(--c-green-dark);
    opacity: 0.85;
    position: relative;
    z-index: 2;
  }

  /* Delays escalonados pra parecer orgânico */
  .step-h:nth-child(1) .step-h-visual::before { animation-delay: 0s; }
  .step-h:nth-child(2) .step-h-visual::before { animation-delay: 1.3s; }
  .step-h:nth-child(3) .step-h-visual::before { animation-delay: 2.6s; }
  .step-h:nth-child(1) .step-h-icon::after { animation-delay: 0.4s; }
  .step-h:nth-child(2) .step-h-icon::after { animation-delay: 1.9s; }
  .step-h:nth-child(3) .step-h-icon::after { animation-delay: 3.4s; }

  @keyframes icon-glow-pulse {
    0%, 100% { opacity: 0.65; transform: scale(1); }
    50% { opacity: 1; transform: scale(1.08); }
  }
  @keyframes icon-shine {
    0%, 30% { transform: translateX(-100%) skewX(-15deg); }
    60%, 100% { transform: translateX(380%) skewX(-15deg); }
  }

  /* === Número gigante (elemento visual dominante) === */
  .step-h-number {
    font-size: 140px;
    line-height: 1;
    font-weight: 500;
    color: var(--c-green-dark);
    letter-spacing: -4px;
    margin-bottom: 24px;
    position: relative;
    z-index: 2;
  }

  /* === Corpo do step === */
  .step-h-body { max-width: 320px; }
  .step-h-title {
    font-size: 22px;
    margin-bottom: 10px;
    color: var(--c-green-dark);
    font-weight: 500;
  }
  .step-h-desc {
    font-size: 14px;
    color: var(--c-green-dark);
    opacity: 0.85;
    line-height: 1.6;
    margin: 0;
  }

  /* === Linhas conectoras (posicionadas via JS no desktop) === */
  .steps-h-segment {
    position: absolute;
    background: rgba(13,66,63,0.35);
    border-radius: 1px;
    pointer-events: none;
    z-index: 0;
    transform: scaleX(0);
    transform-origin: left center;
    transition: transform 1.2s cubic-bezier(0.22, 0.61, 0.36, 1);
  }
  .como-funciona-bg.is-playing .steps-h-segment[data-segment="1"] {
    transform: scaleX(1);
    transition-delay: 0.4s;
  }
  .como-funciona-bg.is-playing .steps-h-segment[data-segment="2"] {
    transform: scaleX(1);
    transition-delay: 0.8s;
  }

  /* === Animação de entrada em cadeia (visual → number → body) === */
  .step-h-visual,
  .step-h-number,
  .step-h-body {
    opacity: 0;
    transform: translateY(20px);
    transition:
      opacity 0.7s cubic-bezier(0.22, 0.61, 0.36, 1),
      transform 0.7s cubic-bezier(0.22, 0.61, 0.36, 1);
  }
  .step-h-number {
    transform: translateY(20px) scale(0.85);
  }

  .como-funciona-bg.is-playing .step-h:nth-child(1) .step-h-visual { transition-delay: 0.2s; }
  .como-funciona-bg.is-playing .step-h:nth-child(1) .step-h-number { transition-delay: 0.3s; }
  .como-funciona-bg.is-playing .step-h:nth-child(1) .step-h-body { transition-delay: 0.4s; }
  .como-funciona-bg.is-playing .step-h:nth-child(2) .step-h-visual { transition-delay: 0.5s; }
  .como-funciona-bg.is-playing .step-h:nth-child(2) .step-h-number { transition-delay: 0.6s; }
  .como-funciona-bg.is-playing .step-h:nth-child(2) .step-h-body { transition-delay: 0.7s; }
  .como-funciona-bg.is-playing .step-h:nth-child(3) .step-h-visual { transition-delay: 0.8s; }
  .como-funciona-bg.is-playing .step-h:nth-child(3) .step-h-number { transition-delay: 0.9s; }
  .como-funciona-bg.is-playing .step-h:nth-child(3) .step-h-body { transition-delay: 1.0s; }

  .como-funciona-bg.is-playing .step-h-visual,
  .como-funciona-bg.is-playing .step-h-body {
    opacity: 1;
    transform: translateY(0);
  }
  .como-funciona-bg.is-playing .step-h-number {
    opacity: 1;
    transform: translateY(0) scale(1);
  }

  @media (prefers-reduced-motion: reduce) {
    .step-h-visual, .step-h-number, .step-h-body {
      opacity: 1; transform: none; transition: none;
    }
    .steps-h-segment { transform: scaleX(1); transition: none; }
    .step-h-visual::before, .step-h-icon::after { animation: none; }
  }

  /* === Mobile === */
  @media (max-width: 900px) {
    .steps-h {
      grid-template-columns: 1fr;
      gap: 48px;
      margin-top: 40px;
      padding: 0;
    }
    .step-h-visual {
      width: 72px; height: 72px; margin-bottom: 4px;
    }
    .step-h-icon { width: 72px; height: 72px; }
    .step-h-icon svg { width: 32px; height: 32px; }
    .step-h-number {
      font-size: 80px;
      letter-spacing: -2px;
      margin-bottom: 16px;
    }
    .step-h-body { max-width: 100%; }
    .step-h-title { font-size: 20px; }
    .step-h-desc { font-size: 14px; }
    .steps-h-segment { display: none; }
  }
</style>

<script>
  // ===== ANIMAÇÃO DA SEÇÃO COMO FUNCIONA =====
  // - Dispara UMA VEZ quando a seção entra no viewport (classe .is-playing)
  // - Calcula posição dos 2 segmentos (entre número 1-2 e 2-3) baseado no rect real
  (function() {
    const section = document.querySelector<HTMLElement>('.como-funciona-bg');
    if (!section) return;

    const numbers = section.querySelectorAll<HTMLElement>('.step-h-number');
    const segments = section.querySelectorAll<HTMLElement>('.steps-h-segment');
    const stepsContainer = section.querySelector<HTMLElement>('.steps-h');

    const layoutSegments = () => {
      const isMobile = window.matchMedia('(max-width: 900px)').matches;
      if (isMobile) {
        segments.forEach(s => {
          s.style.top = ''; s.style.left = ''; s.style.width = ''; s.style.height = '';
        });
        return;
      }
      if (numbers.length < 3 || segments.length < 2 || !stepsContainer) return;

      const containerRect = stepsContainer.getBoundingClientRect();
      const num1 = numbers[0].getBoundingClientRect();
      const num2 = numbers[1].getBoundingClientRect();
      const num3 = numbers[2].getBoundingClientRect();

      const lineY = (num1.top + num1.height * 0.72) - containerRect.top;
      const RESPIRO = 18;

      const seg1_left = (num1.right - containerRect.left) + RESPIRO;
      const seg1_width = (num2.left - containerRect.left) - seg1_left - RESPIRO;
      const seg2_left = (num2.right - containerRect.left) + RESPIRO;
      const seg2_width = (num3.left - containerRect.left) - seg2_left - RESPIRO;

      segments[0].style.top = `${lineY}px`;
      segments[0].style.left = `${seg1_left}px`;
      segments[0].style.width = `${Math.max(0, seg1_width)}px`;
      segments[0].style.height = '2px';

      segments[1].style.top = `${lineY}px`;
      segments[1].style.left = `${seg2_left}px`;
      segments[1].style.width = `${Math.max(0, seg2_width)}px`;
      segments[1].style.height = '2px';
    };

    layoutSegments();
    let resizeTimer: number | null = null;
    window.addEventListener('resize', () => {
      if (resizeTimer) window.clearTimeout(resizeTimer);
      resizeTimer = window.setTimeout(layoutSegments, 100);
    });

    let played = false;
    const play = () => {
      if (played) return;
      played = true;
      layoutSegments();
      section.classList.add('is-playing');
    };

    const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    if (prefersReducedMotion) { play(); return; }

    if ('IntersectionObserver' in window) {
      const observer = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            play();
            observer.disconnect();
          }
        });
      }, { threshold: 0.3 });
      observer.observe(section);
    } else {
      play();
    }
  })();
</script>
