    color: var(--c-text-muted);
    margin: 12px 0 16px;
    line-height: 1.6;
    max-width: 280px;
  }
  .footer-social {
    display: flex;
    gap: 12px;
  }
  .footer-social a {
    color: var(--c-green-dark);
    transition: color 0.15s;
  }
  .footer-social a:hover { color: #1D9E75; }

  .footer-col h4 {
    font-size: 13px;
    color: var(--c-green-dark);
    font-weight: 500;
    margin-bottom: 14px;
  }
  .footer-col a {
    display: block;
    font-size: 13px;
    color: var(--c-text-muted);
    margin-bottom: 8px;
    transition: color 0.15s;
  }
  .footer-col a:hover { color: var(--c-green-dark); }

  .footer-legal {
    padding-top: 28px;
    border-top: 1px solid rgba(13,66,63,0.1);
    font-size: 12px;
    color: var(--c-text-muted);
    line-height: 1.8;
  }
  .footer-legal p { margin: 0; }
  .footer-legal strong { color: var(--c-green-dark); font-weight: 500; }
  .footer-copy { margin-top: 16px; opacity: 0.7; }

  @media (max-width: 1000px) {
    .footer-grid {
      grid-template-columns: 2fr 1fr 1fr;
    }
  }
  @media (max-width: 700px) {
    .footer-grid { grid-template-columns: 1fr 1fr; }
  }
  @media (max-width: 480px) {
    .footer-grid { grid-template-columns: 1fr; }
  }
</style>
