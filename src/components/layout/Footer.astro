<style>
  .footer {
    background: #fff;
    padding: 64px 0 32px;
    border-top: 1px solid rgba(13,66,63,0.08);
  }
  .footer-grid {
    display: grid;
    grid-template-columns: 2fr 1fr 1fr 1fr;
    gap: 48px;
    margin-bottom: 48px;
  }
  .footer-logo-text {
    font-weight: 600;
    font-size: 22px;
    color: var(--c-green-dark);
    letter-spacing: -0.5px;
    display: inline-block;
    margin-bottom: 12px;
  }
  .footer-tagline {
    font-size: 14px;
    color: rgba(13,66,63,0.7);
    margin: 0;
    max-width: 240px;
  }
  .footer-col h4 {
    font-size: 13px;
    font-weight: 600;
    color: var(--c-green-dark);
    margin: 0 0 16px;
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }
  .footer-col ul {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }
  .footer-col a {
    font-size: 14px;
    color: rgba(13,66,63,0.75);
    transition: color 0.15s ease;
  }
  .footer-col a:hover { color: var(--c-green-dark); }
  .footer-legal {
    border-top: 1px solid rgba(13,66,63,0.08);
    padding-top: 32px;
    font-size: 13px;
    color: rgba(13,66,63,0.6);
  }
  .footer-legal p { margin: 0 0 12px; }
  .footer-copy { margin-top: 24px !important; font-size: 12px; }

  @media (max-width: 900px) {
    .footer-grid {
      grid-template-columns: 1fr 1fr;
      gap: 32px;
    }
  }
  @media (max-width: 600px) {
    .footer-grid { grid-template-columns: 1fr; }
  }
</style>
