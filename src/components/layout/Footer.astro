<style>
  footer {
    background: #FFFFFF;
    padding: 60px 0 40px;
    border-top: 1px solid rgba(13,66,63,0.12);
  }
  .footer-grid {
    display: grid;
    grid-template-columns: 2fr 1fr 1fr 1fr;
    gap: 32px;
    margin-bottom: 40px;
  }

  /* Reserva de espaço pra logo — mesmo padrão do Header */
  .footer-logo {
    display: inline-flex;
    align-items: center;
    height: 28px;
    min-width: 100px;
    color: var(--c-green-dark);
    margin-bottom: 0;
  }
  .footer-logo img {
    height: 28px;
    width: auto;
    display: block;
  }
  .footer-logo-fallback {
    font-size: 22px;
    font-weight: 500;
    color: var(--c-green-dark);
    letter-spacing: -1px;
    line-height: 1;
  }

  .footer-brand p {
    font-size: 13px;
    color: var(--c-text-muted);
    margin: 12px 0 16px;
    line-height: 1.6;
    max-width: 280px;
  }
  .footer-social {
    display: flex;
    gap: 12px;
  }
  .footer-social a {
    color: var(--c-green-dark);
    transition: color 0.15s;
  }
  .footer-social a:hover { color: #1D9E75; }

  .footer-col h4 {
    font-size: 13px;
    color: var(--c-green-dark);
    font-weight: 500;
    margin-bottom: 14px;
  }
  .footer-col a {
    display: block;
    font-size: 13px;
    color: var(--c-text-muted);
    margin-bottom: 8px;
    transition: color 0.15s;
  }
  .footer-col a:hover { color: var(--c-green-dark); }

  .footer-legal {
    padding-top: 28px;
    border-top: 1px solid rgba(13,66,63,0.1);
    font-size: 12px;
    color: var(--c-text-muted);
    line-height: 1.8;
  }
  .footer-legal p { margin: 0; }
  .footer-legal strong { color: var(--c-green-dark); font-weight: 500; }
  .footer-copy { margin-top: 16px; opacity: 0.7; }

  @media (max-width: 900px) {
    .footer-grid { grid-template-columns: 1fr 1fr; }
  }
  @media (max-width: 560px) {
    .footer-grid { grid-template-columns: 1fr; }
  }
</style>
