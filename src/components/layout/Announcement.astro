---
// Banner topo: anúncio do investimento R$ 2,5M (Startups.com.br)
// TODO: quando expirar o anúncio, trocar copy ou ocultar com flag
---

<aside class="announcement" role="region" aria-label="Anúncio">
  <div class="announcement-inner">
    <span class="announcement-icon" aria-hidden="true">✨</span>
    <p>
      Selvia captou R$ 2,5M e lançou conta PJ para médicos —
      <a href="https://startups.com.br" target="_blank" rel="noopener">
        leia no Startups.com.br →
      </a>
    </p>
  </div>
</aside>

<style>
  .announcement {
    background: linear-gradient(90deg, #F4933B 0%, #FFD15C 100%);
    color: #0D423F;
    padding: 10px 16px;
    font-size: 14px;
    font-weight: 500;
  }
  .announcement-inner {
    max-width: 1200px;
    margin: 0 auto;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
  }
  .announcement p {
    margin: 0;
    text-align: center;
  }
  .announcement a {
    text-decoration: underline;
    font-weight: 600;
  }
  .announcement-icon {
    font-size: 16px;
  }
  @media (max-width: 700px) {
    .announcement { font-size: 12px; padding: 8px 12px; }
  }
</style>
