---
// Header sticky com nav e CTA WhatsApp
// 1:1 com _legacy/index.html (linhas 167-212, 1994-2010)
//
// ESPAÇO DA LOGO:
// O <a class="nav-logo"> reserva 28px de altura e tem display:inline-flex pra centralizar.
// Enquanto a logo PNG não estiver disponível, mostra o fallback textual "selvia".
//
// Quando a logo PNG estiver pronta:
//   1. Salvar em /public/logo.png (e idealmente /public/logo@2x.png pra retina)
//   2. Trocar o <span class="nav-logo-fallback">selvia</span> por:
//      <img src="/logo.png" srcset="/logo.png 1x, /logo@2x.png 2x"
//           alt="Selvia" width="200" height="56" />
//   3. Remover a classe .nav-logo-fallback e o <style> dela (se quiser limpar)
---

<header>
  <div class="container nav">
    <a href="/" class="nav-logo" aria-label="Selvia">
      <!-- TODO: substituir pelo <img src="/logo.png" ...> quando a logo estiver pronta -->
      <img src="/logo.png" alt="Selvia" width="100" height="28">
    </a>

    <nav class="nav-links" aria-label="Navegação principal">
      <a href="#verticais">Para você</a>
      <a href="#precos">Preços</a>
      <a href="#calculadora">Calculadora</a>
      <a href="#blog">Blog</a>
      <a href="/contabilidades" class="nav-link-secondary" data-future-page="contabilidades">
        Para contabilidades
      </a>
    </nav>

    <a href="https://api.whatsapp.com/send?phone=5511936220451&text=Ol%C3%A1!%20Vim%20do%20site%20e%20gostaria%20de%20saber%20mais%20sobre%20os%20servi%C3%A7os!"
       target="_blank" rel="noopener" class="btn-primary btn-small">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor"
           stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M3 21l1.65 -3.8a9 9 0 1 1 3.4 2.9l-5.05 .9"></path>
        <path d="M9 10a.5 .5 0 0 0 1 0v-1a.5 .5 0 0 0 -1 0v1a5 5 0 0 0 5 5h1a.5 .5 0 0 0 0 -1h-1a.5 .5 0 0 0 0 1"></path>
      </svg>
      WhatsApp
    </a>
  </div>
</header>

<style>
  header {
    position: sticky;
    top: 0;
    z-index: 100;
    background: rgba(255,255,255,0.97);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    border-bottom: 1px solid rgba(13,66,63,0.12);
  }
  .nav {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 16px 0;
  }

  /* Reserva de espaço pra logo — funciona pro fallback textual e pra <img> futura.
     A altura 28px é a referência: quando a <img> entrar, mantém width="100" height="28"
     que a posição não desloca. */
  .nav-logo {
    display: inline-flex;
    align-items: center;
    height: 28px;
    min-width: 100px;
    color: var(--c-green-dark);
  }
  .nav-logo img {
    height: 28px;
    width: auto;
    display: block;
  }

  /* Fallback textual enquanto a logo PNG não chega */
  .nav-logo-fallback {
    font-size: 22px;
    font-weight: 500;
    color: var(--c-green-dark);
    letter-spacing: -1px;
    line-height: 1;
  }

  .nav-links {
    display: flex;
    gap: 28px;
    align-items: center;
  }
  .nav-links a {
    font-size: 14px;
    color: var(--c-text-muted-strong);
    transition: color 0.15s;
  }
  .nav-links a:hover { color: var(--c-green-dark); }

  /* Link secundário no header (pra páginas futuras como /contabilidades) */
  .nav-link-secondary {
    font-weight: 500;
    color: var(--c-green-dark) !important;
    padding: 8px 14px;
    border-radius: 8px;
    border: 1px solid rgba(13,66,63,0.15);
    transition: all 0.15s;
  }
  .nav-link-secondary:hover {
    background: rgba(13,66,63,0.04);
    border-color: rgba(13,66,63,0.35);
  }

  /* Mobile: legacy esconde os links da nav, sem hamburger */
  @media (max-width: 900px) {
    .nav-links { display: none; }
  }
</style>
