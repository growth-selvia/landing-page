---
// Header sticky com nav e CTA WhatsApp
//
// MUDANÇAS (sub-etapa F):
//   - Novo submenu "Produtos" com dropdown (Assistente Financeira, Agendamento de Plantão)
//   - Submenu mostra no hover (desktop) e expande no clique (mobile)
//   - Highlight visual quando URL é uma das LPs de produto
//   - Mantém o link "Blog" do header anterior

const pathname = Astro.url.pathname;
const isBlogActive = pathname === '/blog' || pathname.startsWith('/blog/');
const blogLinkClass = isBlogActive ? 'nav-link-active' : '';

const isProdutosActive =
  pathname === '/assistente-financeira' || pathname === '/agendamento-de-plantao';
const produtosLinkClass = isProdutosActive ? 'nav-link-active' : '';

const isAssistenteActive = pathname === '/assistente-financeira';
const isAgendamentoActive = pathname === '/agendamento-de-plantao';
---

<header>
  <div class="container nav">
    <a href="/" class="nav-logo" aria-label="Selvia">
      <img src="/logo.png" alt="Selvia" width="3500" height="1500">
    </a>

    <nav class="nav-links" aria-label="Navegação principal">
      <a href="/#verticais">Para você</a>
      <a href="/#precos">Preços</a>
      <a href="/#calculadora">Calculadora</a>

      <!-- Submenu Produtos com dropdown -->
      <div class="nav-dropdown">
        <button
          type="button"
          class={`nav-dropdown-trigger ${produtosLinkClass}`}
          aria-haspopup="true"
          aria-expanded="false"
        >
          Produtos
          <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor"
               stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <polyline points="6 9 12 15 18 9"></polyline>
          </svg>
        </button>

        <div class="nav-dropdown-menu" role="menu">
          
            href="/assistente-financeira"
            class={isAssistenteActive ? 'nav-dropdown-item nav-dropdown-item-active' : 'nav-dropdown-item'}
            role="menuitem"
          >
            <span class="nav-dropdown-item-title">Assistente Financeira</span>
            <span class="nav-dropdown-item-desc">Suas finanças no WhatsApp, sem planilha</span>
          </a>
          
            href="/agendamento-de-plantao"
            class={isAgendamentoActive ? 'nav-dropdown-item nav-dropdown-item-active' : 'nav-dropdown-item'}
            role="menuitem"
          >
            <span class="nav-dropdown-item-title">Agendamento de Plantão</span>
            <span class="nav-dropdown-item-desc">Pra médicos, gratuito, direto no WhatsApp</span>
          </a>
        </div>
      </div>

      <a href="/blog" class={blogLinkClass}>Blog</a>

      <a href="/contabilidades" class="nav-link-secondary" data-future-page="contabilidades">
        Para contabilidades
      </a>
    </nav>

    <a href="https://api.whatsapp.com/send?phone=5511936220451&text=Ol%C3%A1!%20Vim%20do%20site%20e%20gostaria%20de%20saber%20mais%20sobre%20os%20servi%C3%A7os!"
       target="_blank" rel="noopener" class="btn-primary btn-small">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor"
           stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M3 21l1.65 -3.8a9 9 0 1 1 3.4 2.9l-5.05 .9"></path>
        <path d="M9 10a.5 .5 0 0 0 1 0v-1a.5 .5 0 0 0 -1 0v1a5 5 0 0 0 5 5h1a.5 .5 0 0 0 0 -1h-1a.5 .5 0 0 0 0 1"></path>
      </svg>
      WhatsApp
    </a>
  </div>
</header>

<script>
  // === Comportamento do dropdown "Produtos" ===
  // Desktop: hover já abre via CSS, mas adicionamos aria-expanded também
  // Mobile/Touch: precisa de click pra abrir, porque hover não funciona

  const trigger = document.querySelector('.nav-dropdown-trigger') as HTMLButtonElement;
  const dropdown = document.querySelector('.nav-dropdown') as HTMLElement;

  if (trigger && dropdown) {
    trigger.addEventListener('click', (e) => {
      e.preventDefault();
      const isOpen = dropdown.classList.contains('nav-dropdown-open');
      if (isOpen) {
        dropdown.classList.remove('nav-dropdown-open');
        trigger.setAttribute('aria-expanded', 'false');
      } else {
        dropdown.classList.add('nav-dropdown-open');
        trigger.setAttribute('aria-expanded', 'true');
      }
    });

    // Fecha quando clica fora
    document.addEventListener('click', (e) => {
      const target = e.target as Node;
      if (!dropdown.contains(target)) {
        dropdown.classList.remove('nav-dropdown-open');
        trigger.setAttribute('aria-expanded', 'false');
      }
    });

    // Fecha com ESC
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') {
        dropdown.classList.remove('nav-dropdown-open');
        trigger.setAttribute('aria-expanded', 'false');
      }
    });
  }
</script>

<style>
  header {
    position: sticky;
    top: 0;
    z-index: 100;
    background: rgba(255,255,255,0.97);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    border-bottom: 1px solid rgba(13,66,63,0.12);
  }
  .nav {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 16px 0;
  }

  .nav-logo {
    display: inline-flex;
    align-items: center;
    height: 44px;
    min-width: 160px;
    color: var(--c-green-dark);
  }
  .nav-logo img {
    height: 44px;
    width: auto;
    max-width: 200px;
    display: block;
  }

  .nav-links {
    display: flex;
    gap: 28px;
    align-items: center;
  }
  .nav-links > a {
    font-size: 14px;
    color: var(--c-text-muted-strong);
    transition: color 0.15s;
    position: relative;
  }
  .nav-links > a:hover { color: var(--c-green-dark); }

  /* Highlight do link ativo */
  .nav-link-active {
    color: var(--c-green-dark) !important;
    font-weight: 500;
  }
  .nav-link-active::after {
    content: '';
    position: absolute;
    bottom: -6px;
    left: 0;
    right: 0;
    height: 2px;
    background: var(--c-green-light);
    border-radius: 2px;
  }

  /* === Dropdown Produtos === */
  .nav-dropdown {
    position: relative;
  }

  .nav-dropdown-trigger {
    background: none;
    border: none;
    cursor: pointer;
    font-family: inherit;
    font-size: 14px;
    color: var(--c-text-muted-strong);
    display: inline-flex;
    align-items: center;
    gap: 4px;
    padding: 0;
    transition: color 0.15s;
    position: relative;
  }
  .nav-dropdown-trigger:hover {
    color: var(--c-green-dark);
  }
  .nav-dropdown-trigger svg {
    transition: transform 0.2s;
  }
  .nav-dropdown:hover .nav-dropdown-trigger svg,
  .nav-dropdown-open .nav-dropdown-trigger svg {
    transform: rotate(180deg);
  }

  .nav-dropdown-menu {
    position: absolute;
    top: calc(100% + 12px);
    left: 50%;
    transform: translateX(-50%) translateY(-6px);
    background: #FFFFFF;
    border: 1px solid rgba(13,66,63,0.08);
    border-radius: 12px;
    padding: 8px;
    min-width: 280px;
    box-shadow: 0 16px 32px -12px rgba(13,66,63,0.15);
    opacity: 0;
    visibility: hidden;
    transition: all 0.2s ease;
    z-index: 100;
  }
  .nav-dropdown:hover .nav-dropdown-menu,
  .nav-dropdown-open .nav-dropdown-menu {
    opacity: 1;
    visibility: visible;
    transform: translateX(-50%) translateY(0);
  }

  /* Ponte invisível entre o trigger e o menu pro hover não quebrar */
  .nav-dropdown::after {
    content: '';
    position: absolute;
    top: 100%;
    left: 0;
    right: 0;
    height: 12px;
    background: transparent;
  }

  .nav-dropdown-item {
    display: block;
    padding: 12px 14px;
    border-radius: 8px;
    text-decoration: none;
    color: var(--c-green-dark);
    transition: background 0.15s;
  }
  .nav-dropdown-item:hover {
    background: rgba(105,228,112,0.1);
  }
  .nav-dropdown-item-active {
    background: rgba(105,228,112,0.15);
  }

  .nav-dropdown-item-title {
    display: block;
    font-size: 14px;
    font-weight: 500;
    color: var(--c-green-dark);
    margin-bottom: 2px;
  }
  .nav-dropdown-item-desc {
    display: block;
    font-size: 12px;
    color: var(--c-text-muted);
    line-height: 1.4;
  }

  /* Link secundário no header */
  .nav-link-secondary {
    font-weight: 500;
    color: var(--c-green-dark) !important;
    padding: 8px 14px;
    border-radius: 8px;
    border: 1px solid rgba(13,66,63,0.15);
    transition: all 0.15s;
  }
  .nav-link-secondary:hover {
    background: rgba(13,66,63,0.04);
    border-color: rgba(13,66,63,0.35);
  }
  .nav-link-secondary::after { display: none; }

  /* Mobile */
  @media (max-width: 900px) {
    .nav-links { display: none; }
  }
  @media (max-width: 600px) {
    .nav-logo, .nav-logo img {
      height: 36px;
    }
    .nav-logo {
      min-width: 130px;
    }
    .nav-logo img {
      max-width: 170px;
    }
  }
</style>
