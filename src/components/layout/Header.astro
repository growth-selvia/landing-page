---
// Header sticky com nav e CTA WhatsApp
// 1:1 com _legacy/index.html (linhas 167-212, 1994-2010)
//
// MUDANÇAS (sub-etapa E):
//   - "Blog" agora aponta pra /blog (rota real, não âncora)
//   - "Blog" tem highlight visual quando URL começa com /blog
//   - Âncoras "Para você", "Preços", "Calculadora" agora apontam pra /#... 
//     pra funcionar de qualquer página (não só da home)

const pathname = Astro.url.pathname;
const isBlogActive = pathname === '/blog' || pathname.startsWith('/blog/');
const blogLinkClass = isBlogActive ? 'nav-link-active' : '';
---

<header>
  <div class="container nav">
    <a href="/" class="nav-logo" aria-label="Selvia">
      <img src="/logo.png" alt="Selvia" width="3500" height="1500">
    </a>

    <nav class="nav-links" aria-label="Navegação principal">
      <a href="/#verticais">Para você</a>
      <a href="/#precos">Preços</a>
      <a href="/#calculadora">Calculadora</a>
      <a href="/blog" class={blogLinkClass}>Blog</a>
      <a href="/contabilidades" class="nav-link-secondary" data-future-page="contabilidades">
        Para contabilidades
      </a>
    </nav>

    <a href="https://api.whatsapp.com/send?phone=5511936220451&text=Ol%C3%A1!%20Vim%20do%20site%20e%20gostaria%20de%20saber%20mais%20sobre%20os%20servi%C3%A7os!"
       target="_blank" rel="noopener" class="btn-primary btn-small">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor"
           stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M3 21l1.65 -3.8a9 9 0 1 1 3.4 2.9l-5.05 .9"></path>
        <path d="M9 10a.5 .5 0 0 0 1 0v-1a.5 .5 0 0 0 -1 0v1a5 5 0 0 0 5 5h1a.5 .5 0 0 0 0 -1h-1a.5 .5 0 0 0 0 1"></path>
      </svg>
      WhatsApp
    </a>
  </div>
</header>

<style>
  header {
    position: sticky;
    top: 0;
    z-index: 100;
    background: rgba(255,255,255,0.97);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    border-bottom: 1px solid rgba(13,66,63,0.12);
  }
  .nav {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 16px 0;
  }

  .nav-logo {
    display: inline-flex;
    align-items: center;
    height: 44px;
    min-width: 160px;
    color: var(--c-green-dark);
  }
  .nav-logo img {
    height: 44px;
    width: auto;
    max-width: 200px;
    display: block;
  }

  .nav-logo-fallback {
    font-size: 22px;
    font-weight: 500;
    color: var(--c-green-dark);
    letter-spacing: -1px;
    line-height: 1;
  }

  .nav-links {
    display: flex;
    gap: 28px;
    align-items: center;
  }
  .nav-links a {
    font-size: 14px;
    color: var(--c-text-muted-strong);
    transition: color 0.15s;
    position: relative;
  }
  .nav-links a:hover { color: var(--c-green-dark); }

  /* Highlight quando o link tá "ativo" (rota atual) */
  .nav-link-active {
    color: var(--c-green-dark) !important;
    font-weight: 500;
  }
  .nav-link-active::after {
    content: '';
    position: absolute;
    bottom: -6px;
    left: 0;
    right: 0;
    height: 2px;
    background: var(--c-green-light);
    border-radius: 2px;
  }

  .nav-link-secondary {
    font-weight: 500;
    color: var(--c-green-dark) !important;
    padding: 8px 14px;
    border-radius: 8px;
    border: 1px solid rgba(13,66,63,0.15);
    transition: all 0.15s;
  }
  .nav-link-secondary:hover {
    background: rgba(13,66,63,0.04);
    border-color: rgba(13,66,63,0.35);
  }
  /* O secundário não ganha underline mesmo quando hover */
  .nav-link-secondary::after { display: none; }

  @media (max-width: 900px) {
    .nav-links { display: none; }
  }
  @media (max-width: 600px) {
    .nav-logo, .nav-logo img {
      height: 36px;
    }
    .nav-logo {
      min-width: 130px;
    }
    .nav-logo img {
      max-width: 170px;
    }
  }
</style>
