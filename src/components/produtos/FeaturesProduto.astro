---
/**
 * FeaturesProduto.astro — grid de features visuais com ícone + título + descrição
 *
 * Recebe via props:
 *   - features: array de { icon, title, description }
 *   - sectionTitle (opcional): título da seção
 *
 * Ícones disponíveis (via prop "icon" do produto):
 *   - whatsapp, shield, chart, target, calendar, cash, clock
 *
 * Layout: grid responsivo. 2 colunas em desktop, 1 em mobile.
 * Cada feature tem ícone SVG inline (sem dependência externa).
 */

interface Feature {
  icon: string;
  title: string;
  description: string;
}

interface Props {
  features: Feature[];
  sectionTitle?: string;
  sectionEyebrow?: string;
}

const { features, sectionTitle, sectionEyebrow } = Astro.props;
---

<section class="features-produto">
  <div class="container">
    {sectionEyebrow && <span class="pill pill-dark">{sectionEyebrow}</span>}
    {sectionTitle && <h2 class="features-produto-title">{sectionTitle}</h2>}

    <div class="features-produto-grid">
      {features.map((feature) => (
        <div class="feature-card">
          <div class="feature-icon">
            {feature.icon === 'whatsapp' && (
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M3 21l1.65 -3.8a9 9 0 1 1 3.4 2.9l-5.05 .9"></path>
              </svg>
            )}
            {feature.icon === 'shield' && (
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M12 3l8 4v6c0 5-3.5 8.5-8 10c-4.5-1.5-8-5-8-10V7l8-4z"></path>
                <path d="M9 12l2 2 4-4"></path>
              </svg>
            )}
            {feature.icon === 'chart' && (
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M3 3v18h18"></path>
                <path d="M7 14l3 -3l3 3l5 -5"></path>
              </svg>
            )}
            {feature.icon === 'target' && (
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="12" cy="12" r="9"></circle>
                <circle cx="12" cy="12" r="5"></circle>
                <circle cx="12" cy="12" r="1"></circle>
              </svg>
            )}
            {feature.icon === 'calendar' && (
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <rect x="4" y="5" width="16" height="16" rx="2"></rect>
                <line x1="16" y1="3" x2="16" y2="7"></line>
                <line x1="8" y1="3" x2="8" y2="7"></line>
                <line x1="4" y1="11" x2="20" y2="11"></line>
              </svg>
            )}
            {feature.icon === 'cash' && (
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <rect x="3" y="6" width="18" height="12" rx="2"></rect>
                <circle cx="12" cy="12" r="3"></circle>
                <path d="M6 9h.01"></path>
                <path d="M18 15h.01"></path>
              </svg>
            )}
            {feature.icon === 'clock' && (
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="12" cy="12" r="9"></circle>
                <polyline points="12 7 12 12 15 14"></polyline>
              </svg>
            )}
          </div>
          <h3 class="feature-title">{feature.title}</h3>
          <p class="feature-description">{feature.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .features-produto {
    padding: 72px 0;
    background: #F9F9F9;
  }

  .features-produto-title {
    font-size: clamp(28px, 4vw, 36px);
    font-weight: 500;
    color: var(--c-green-dark);
    letter-spacing: -0.8px;
    line-height: 1.2;
    margin: 12px 0 40px;
    max-width: 600px;
  }

  .features-produto-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 20px;
  }

  .feature-card {
    background: #FFFFFF;
    padding: 28px;
    border-radius: 14px;
    border: 1px solid rgba(13,66,63,0.08);
    transition: all 0.2s;
  }
  .feature-card:hover {
    border-color: var(--c-green-light);
    transform: translateY(-2px);
    box-shadow: 0 12px 28px -12px rgba(105,228,112,0.18);
  }

  .feature-icon {
    width: 44px;
    height: 44px;
    background: var(--c-green-light);
    color: var(--c-green-dark);
    border-radius: 10px;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 18px;
  }
  .feature-icon svg {
    width: 22px;
    height: 22px;
  }

  .feature-title {
    font-size: 17px;
    font-weight: 500;
    color: var(--c-green-dark);
    line-height: 1.3;
    margin: 0 0 8px;
    letter-spacing: -0.2px;
  }

  .feature-description {
    font-size: 14px;
    color: var(--c-text-muted-strong);
    line-height: 1.6;
    margin: 0;
  }

  @media (max-width: 700px) {
    .features-produto {
      padding: 56px 0;
    }
    .feature-card {
      padding: 24px;
    }
  }
</style>
