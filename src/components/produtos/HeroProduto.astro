---
/**
 * HeroProduto.astro — hero das LPs de subprodutos Selvia
 *
 * MUDANÇA (sub-etapa F): o CTA agora abre o LeadFormModal em vez de ir
 * direto pro WhatsApp. O LeadFormModal precisa estar presente na página
 * que importa esse Hero (geralmente no fim da página, antes do Footer).
 *
 * O botão tem o atributo data-open-lead-modal, que é o trigger genérico
 * que o script do modal escuta.
 */

interface Props {
  eyebrow: string;
  h1: string;
  sub: string;
  ctaLabel: string;
  whatsappContext: string;  // mantido pra compatibilidade, não é mais usado aqui
}

const { eyebrow, h1, sub, ctaLabel } = Astro.props;
---

<section class="hero-produto">
  <div class="container">
    <span class="hero-produto-pill">{eyebrow}</span>
    <h1 class="hero-produto-h1">{h1}</h1>
    <p class="hero-produto-sub">{sub}</p>

    <button type="button" class="btn-primary hero-produto-cta" data-open-lead-modal>
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor"
           stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M3 21l1.65 -3.8a9 9 0 1 1 3.4 2.9l-5.05 .9"></path>
      </svg>
      {ctaLabel}
    </button>
  </div>
</section>

<style>
  .hero-produto {
    padding: 80px 0 60px;
    background: #FFFFFF;
    text-align: center;
    position: relative;
    overflow: hidden;
  }

  .hero-produto::before {
    content: '';
    position: absolute;
    top: -100px;
    left: 50%;
    transform: translateX(-50%);
    width: 800px;
    height: 400px;
    background: radial-gradient(ellipse, rgba(105,228,112,0.10) 0%, transparent 60%);
    pointer-events: none;
  }
  .hero-produto > * {
    position: relative;
    z-index: 1;
  }

  .hero-produto-pill {
    display: inline-block;
    background: var(--c-green-light);
    color: var(--c-green-dark);
    padding: 7px 16px;
    border-radius: 100px;
    font-size: 12px;
    font-weight: 500;
    letter-spacing: 0.3px;
    margin-bottom: 24px;
  }

  .hero-produto-h1 {
    font-size: clamp(36px, 6vw, 56px);
    font-weight: 500;
    color: var(--c-green-dark);
    line-height: 1.1;
    letter-spacing: -1.5px;
    margin: 0 auto 20px;
    max-width: 800px;
  }

  .hero-produto-sub {
    font-size: 18px;
    line-height: 1.55;
    color: var(--c-text-muted-strong);
    max-width: 600px;
    margin: 0 auto 36px;
  }

  .hero-produto-cta {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    cursor: pointer;
    border: none;
    font-family: inherit;
    font-size: 14px;
  }

  @media (max-width: 700px) {
    .hero-produto {
      padding: 56px 0 48px;
    }
    .hero-produto-h1 {
      letter-spacing: -0.8px;
    }
    .hero-produto-sub {
      font-size: 16px;
    }
  }
</style>
