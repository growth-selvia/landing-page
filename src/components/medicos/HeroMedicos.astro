---
/**
 * HeroMedicos.astro — hero específico da LP /medicos
 *
 * Diferente do <Hero /> da home (que tenta ser mais amplo), esse hero é
 * focado especificamente em médico PJ. Usa terminologia médica direta
 * (Receita Saúde, plantão, CNPJ) e CTA pra WhatsApp.
 *
 * Layout: 1 coluna centralizada, igual padrão das LPs de produto. Sem
 * mockup, só texto e ícone WhatsApp no botão.
 */

import { medicosHero } from '../../data/medicos.ts';

const whatsappMessage = `Olá! Vim da página de Médicos e gostaria de saber mais sobre a Selvia.`;
const whatsappUrl = `https://api.whatsapp.com/send?phone=5511936220451&text=${encodeURIComponent(whatsappMessage)}`;
---

<section class="hero-medicos">
  <div class="container">
    <span class="hero-medicos-pill">{medicosHero.eyebrow}</span>
    <h1 class="hero-medicos-h1">{medicosHero.h1}</h1>
    <p class="hero-medicos-sub">{medicosHero.sub}</p>

    <div class="hero-medicos-ctas">
      <a href={whatsappUrl} target="_blank" rel="noopener" class="btn-primary hero-medicos-cta">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor"
             stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M3 21l1.65 -3.8a9 9 0 1 1 3.4 2.9l-5.05 .9"></path>
        </svg>
        {medicosHero.ctaLabel}
      </a>

      <a href="#precos" class="hero-medicos-cta-secondary">
        Ver planos
        <span aria-hidden="true">→</span>
      </a>
    </div>

    <div class="hero-medicos-trust">
      <span>+1.000 médicos atendidos</span>
      <span class="hero-medicos-trust-sep" aria-hidden="true">·</span>
      <span>22 estados</span>
      <span class="hero-medicos-trust-sep" aria-hidden="true">·</span>
      <span>Nota 9.7</span>
    </div>
  </div>
</section>

<style>
  .hero-medicos {
    padding: 80px 0 60px;
    background: #FFFFFF;
    text-align: center;
    position: relative;
    overflow: hidden;
  }

  .hero-medicos::before {
    content: '';
    position: absolute;
    top: -100px;
    left: 50%;
    transform: translateX(-50%);
    width: 800px;
    height: 400px;
    background: radial-gradient(ellipse, rgba(105,228,112,0.10) 0%, transparent 60%);
    pointer-events: none;
  }
  .hero-medicos > * {
    position: relative;
    z-index: 1;
  }

  .hero-medicos-pill {
    display: inline-block;
    background: var(--c-green-light);
    color: var(--c-green-dark);
    padding: 7px 16px;
    border-radius: 100px;
    font-size: 12px;
    font-weight: 500;
    letter-spacing: 0.3px;
    margin-bottom: 24px;
  }

  .hero-medicos-h1 {
    font-size: clamp(36px, 6vw, 56px);
    font-weight: 500;
    color: var(--c-green-dark);
    line-height: 1.1;
    letter-spacing: -1.5px;
    margin: 0 auto 20px;
    max-width: 800px;
  }

  .hero-medicos-sub {
    font-size: 18px;
    line-height: 1.55;
    color: var(--c-text-muted-strong);
    max-width: 620px;
    margin: 0 auto 36px;
  }

  .hero-medicos-ctas {
    display: flex;
    gap: 14px;
    justify-content: center;
    align-items: center;
    flex-wrap: wrap;
    margin-bottom: 32px;
  }

  .hero-medicos-cta {
    display: inline-flex;
    align-items: center;
    gap: 10px;
  }

  .hero-medicos-cta-secondary {
    font-size: 14px;
    font-weight: 500;
    color: var(--c-green-dark);
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    gap: 6px;
    transition: gap 0.15s;
  }
  .hero-medicos-cta-secondary:hover {
    gap: 10px;
  }

  .hero-medicos-trust {
    display: flex;
    gap: 10px;
    justify-content: center;
    align-items: center;
    font-size: 13px;
    color: var(--c-text-muted);
    flex-wrap: wrap;
  }
  .hero-medicos-trust-sep {
    opacity: 0.5;
  }

  @media (max-width: 700px) {
    .hero-medicos {
      padding: 56px 0 48px;
    }
    .hero-medicos-h1 {
      letter-spacing: -0.8px;
    }
    .hero-medicos-sub {
      font-size: 16px;
    }
  }
</style>
