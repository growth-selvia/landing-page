---
/**
 * FaqMedicos.astro — FAQ específica da LP /medicos
 *
 * Perguntas focadas em dúvidas reais de médico PJ: recém-formado, Receita
 * Saúde, plantões, MEI, troca de contador. Visualmente igual ao FaqProduto
 * e ao FAQ da home (cards expansíveis em <details>).
 */

import { medicosFaqs } from '../../data/medicos.ts';
---

<section class="faq-medicos" id="faq">
  <div class="container">
    <span class="pill pill-dark">FAQ</span>
    <h2 class="faq-medicos-title">Perguntas frequentes de médicos</h2>

    <div class="faq-medicos-list">
      {medicosFaqs.map((faq) => (
        <details class="faq-medicos-item">
          <summary>{faq.question}</summary>
          <p>{faq.answer}</p>
        </details>
      ))}
    </div>
  </div>
</section>

<style>
  .faq-medicos {
    background:
      radial-gradient(circle, rgba(13,66,63,0.05) 1px, transparent 1.5px) 0 0 / 28px 28px,
      #FFFFFF;
    padding: 72px 0;
    border-top: 1px solid rgba(13,66,63,0.06);
  }

  .faq-medicos-title {
    font-size: clamp(28px, 4vw, 36px);
    font-weight: 500;
    color: var(--c-green-dark);
    letter-spacing: -0.8px;
    line-height: 1.2;
    margin: 12px 0 32px;
    max-width: 600px;
  }

  .faq-medicos-list {
    display: grid;
    gap: 10px;
    max-width: 760px;
  }

  .faq-medicos-item {
    background: #FFFFFF;
    border: 1px solid rgba(13,66,63,0.08);
    border-radius: 12px;
    padding: 18px 22px;
    transition: all 0.2s;
    box-shadow: 0 1px 2px rgba(13,66,63,0.04);
  }
  .faq-medicos-item[open] {
    border-color: var(--c-green-dark);
    box-shadow:
      0 16px 32px -12px rgba(13,66,63,0.15),
      0 4px 8px -4px rgba(105,228,112,0.1);
  }

  .faq-medicos-item summary {
    font-size: 15px;
    font-weight: 500;
    color: var(--c-green-dark);
    cursor: pointer;
    list-style: none;
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 16px;
  }
  .faq-medicos-item summary::-webkit-details-marker { display: none; }
  .faq-medicos-item summary::after {
    content: '+';
    font-size: 22px;
    color: var(--c-green-dark);
    font-weight: 300;
    line-height: 1;
    flex-shrink: 0;
  }
  .faq-medicos-item[open] summary::after { content: '−'; }

  .faq-medicos-item p {
    margin: 12px 0 0;
    font-size: 14px;
    color: var(--c-text-muted-strong);
    line-height: 1.65;
  }

  @media (max-width: 700px) {
    .faq-medicos {
      padding: 56px 0;
    }
  }
</style>
